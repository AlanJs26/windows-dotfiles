description='ensures starship prompt is installed and configured'
url=''
depends=('winget:Starship.Starship')
source=()
# source_on_check=false
# make this health script platform specific. Supported platforms: linux, windows 
platform='windows'

# All items of source will be downloaded and extracted (when necessary)
# all downloaded (or extracted folders) are stored inside ${sourced[@]}
# This script is ran inside a folder over ~/.cache/archdots/pkgname, where all sources are downloaded
#
# $PKGPATH has the path to folder containing this file 

# This function is used to configure the health script
install() {
    $profilePath = $PROFILE.CurrentUserAllHosts
    $profileDir = Split-Path -Parent $profilePath

    if (-not (Test-Path $profileDir)) {
        New-Item -ItemType Directory -Path $profileDir -Force | Out-Null
    }
    if (-not (Test-Path $profilePath)) {
        New-Item -ItemType File -Path $profilePath -Force | Out-Null
    }

    $initLine = 'Invoke-Expression (&starship init powershell)'
    $current = Get-Content $profilePath -ErrorAction SilentlyContinue
    if (-not ($current | Where-Object { $_ -eq $initLine })) {
        Add-Content -Path $profilePath -Value $initLine
    }
}

# This function is used to unconfigure the health script
uninstall() {
    $profilePath = $PROFILE.CurrentUserAllHosts
    $initLine = 'Invoke-Expression (&starship init powershell)'

    if (Test-Path $profilePath) {
        $updated = Get-Content $profilePath -ErrorAction SilentlyContinue | Where-Object { $_ -ne $initLine }
        Set-Content -Path $profilePath -Value $updated
    }
}

# This function should end with exit code 0 when the health script is configured
# and end with exit code 1 when it is unconfigured
check() {
    $hasStarship = (Get-Command starship -ErrorAction SilentlyContinue) -ne $null
    $profilePath = $PROFILE.CurrentUserAllHosts
    $hasInitLine = $false

    if (Test-Path $profilePath) {
        $hasInitLine = Select-String -Path $profilePath -SimpleMatch 'Invoke-Expression (&starship init powershell)' -Quiet
    }

    if ($hasStarship -and $hasInitLine) {
        exit 0
    }

    exit 1
}