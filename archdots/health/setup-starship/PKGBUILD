description='Configura o Starship Prompt no PowerShell e no CMD (via Clink)'
url='https://starship.rs'
depends=('winget:Starship.Starship' 'winget:chrisant996.Clink')
source=()
platform='windows'

install() {
    # Redefinição local de variáveis (necessário para o parser)
    $clinkScriptsDir = Join-Path $env:LOCALAPPDATA "clink"
    $starshipLua = Join-Path $clinkScriptsDir "starship.lua"
    $initLine = 'Invoke-Expression (&starship init powershell)'
    $clinkExe = Join-Path ${env:ProgramFiles(x86)} "clink\clink.exe"

    # --- 1. Configuração PowerShell ---
    $profilePath = $PROFILE.CurrentUserAllHosts
    $profileDir = Split-Path -Parent $profilePath
    
    if (-not (Test-Path $profileDir)) { New-Item -ItemType Directory -Path $profileDir -Force | Out-Null }
    if (-not (Test-Path $profilePath)) { New-Item -ItemType File -Path $profilePath -Force | Out-Null }

    $alreadyExists = Select-String -Path $profilePath -Pattern $initLine -SimpleMatch -Quiet
    if (-not $alreadyExists) {
        Add-Content -Path $profilePath -Value "`n$initLine"
    }

    # --- 2. Configuração Clink (CMD) ---
    if (-not (Test-Path $clinkScriptsDir)) { New-Item -ItemType Directory -Path $clinkScriptsDir -Force | Out-Null }
    
    $luaContent = 'load(io.popen("starship init cmd"):read("*a"))()'
    Set-Content -Path $starshipLua -Value $luaContent -Encoding UTF8

    if (Test-Path $clinkExe) {
        & $clinkExe autorun --install
    }
}

uninstall() {
    $clinkScriptsDir = Join-Path $env:LOCALAPPDATA "clink"
    $starshipLua = Join-Path $clinkScriptsDir "starship.lua"
    $initLine = 'Invoke-Expression (&starship init powershell)'
    $clinkExe = Join-Path ${env:ProgramFiles(x86)} "clink\clink.exe"

    # Remove do PowerShell
    $profilePath = $PROFILE.CurrentUserAllHosts
    if (Test-Path $profilePath) {
        $content = Get-Content $profilePath | Where-Object { $_ -ne $initLine }
        Set-Content -Path $profilePath -Value $content
    }

    # Remove do Clink
    if (Test-Path $starshipLua) { Remove-Item $starshipLua -Force }
}

check() {
    $clinkScriptsDir = Join-Path $env:LOCALAPPDATA "clink"
    $starshipLua = Join-Path $clinkScriptsDir "starship.lua"
    $initLine = 'Invoke-Expression (&starship init powershell)'
    $clinkExe = Join-Path ${env:ProgramFiles(x86)} "clink\clink.exe"

    # Verifica PowerShell
    $profilePath = $PROFILE.CurrentUserAllHosts
    $hasPs = $false
    if (Test-Path $profilePath) { 
        $hasPs = Select-String -Path $profilePath -Pattern $initLine -SimpleMatch -Quiet 
    }

    # Verifica Clink
    $hasClinkLua = Test-Path $starshipLua
    $clinkAutorun = $false
    if (Test-Path $clinkExe) {
        if ((& $clinkExe autorun show) -match "Current AutoRun values") { $clinkAutorun = $true }
    }

    if ($hasPs -and $hasClinkLua -and $clinkAutorun) { exit 0 }
    exit 1
}